{
  "name": "cp-number-lens",
  "displayName": "Number Lens for Competitive Programmers",
  "description": "Visualize numbers, bits, primes, and XOR instantly inside VS Code.",
  "repository": {
    "type": "git",
    "url": "https://github.com/stapankumar/cp-number-lens"
  },
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:cpp",
    "onLanguage:c",
    "onLanguage:python"
  ],
  "main": "./extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "cp-number-lens.openPanel",
        "title": "Number Lens: Open Panel"
      }
    ]
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "competitive programming",
    "bitmask",
    "binary",
    "prime",
    "cp",
    "number analysis"
  ]
}